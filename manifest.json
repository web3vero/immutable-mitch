{
  "manifest_version": 3,
  "name": "Mitch McConnell Status Tracker",
  "version": "1.0",
  "description": "Tracks the latest status of Senator Mitch McConnell using decentralized Web3 tech.",
  "permissions": ["alarms", "storage"],
  "host_permissions": [
    "https://dre-1.warp.cc/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon_unknown.png",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon_unknown.png",
    "48": "icon_unknown.png",
    "128": "icon_unknown.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  }
}
